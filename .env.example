# ─────────────────────────────────────────────────────────────
# NoobxMarketing — Environment Variables
# Copy to `.env.local` and fill in. All NEXT_PUBLIC_* values are
# exposed to the browser. Analytics components no-op when unset.
# ─────────────────────────────────────────────────────────────

# Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://noobxmarketing.com"

# Analytics — leave blank to disable in development
NEXT_PUBLIC_GA_ID=""               # Google Analytics 4, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=""          # Microsoft Clarity project id
NEXT_PUBLIC_META_PIXEL_ID=""       # Meta Pixel id (optional)

# ── Lead delivery (form submissions: contact, audit, newsletter) ──
# Option A (recommended): email via Resend → https://resend.com
RESEND_API_KEY=""                  # re_xxxxx — get it free from resend.com
LEAD_TO_EMAIL="hello@noobxmarketing.com"   # where leads are delivered
# From must be a Resend-verified domain. Defaults to onboarding@resend.dev
# (works for testing; verify your domain before launch for deliverability).
LEAD_FROM_EMAIL="NoobxMarketing <onboarding@resend.dev>"

# Option B (or in addition): forward leads to any webhook
# (Google Sheets Apps Script, Zapier, Make, CRM, Formspree, etc.)
CONTACT_FORM_ENDPOINT=""

# Scheduling — Cal.com (free, open-source Calendly alternative).
# Sign up free at https://cal.com, create an event type, then set:
#   CAL_LINK  = "<username>/<event-slug>"  (powers the on-site popup)
#   BOOKING_URL = full public link (fallback; or use Google Calendar/Zoho here)
NEXT_PUBLIC_CAL_LINK="noobxmarketing/consultation"
NEXT_PUBLIC_BOOKING_URL="https://cal.com/noobxmarketing/consultation"

# Sanity CMS (optional — content currently sourced from /data)
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_READ_TOKEN=""
