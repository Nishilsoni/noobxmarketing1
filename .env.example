# ─────────────────────────────────────────────────────────────
# NoobxMarketing — Environment Variables
# Copy to `.env.local` and fill in. All NEXT_PUBLIC_* values are
# exposed to the browser. Analytics components no-op when unset.
# ─────────────────────────────────────────────────────────────

# Canonical site URL (no trailing slash)
NEXT_PUBLIC_SITE_URL="https://noobxmarketing.com"

# Analytics — leave blank to disable in development
NEXT_PUBLIC_GA_ID=""               # Google Analytics 4, e.g. G-XXXXXXXXXX
NEXT_PUBLIC_CLARITY_ID=""          # Microsoft Clarity project id
NEXT_PUBLIC_META_PIXEL_ID=""       # Meta Pixel id (optional)

# Lead / contact form endpoint (Resend, Formspree, custom API, etc.)
CONTACT_FORM_ENDPOINT=""

# Calendly scheduling link
NEXT_PUBLIC_CALENDLY_URL="https://calendly.com/noobxmarketing/consultation"

# Sanity CMS (optional — content currently sourced from /data)
NEXT_PUBLIC_SANITY_PROJECT_ID=""
NEXT_PUBLIC_SANITY_DATASET="production"
SANITY_API_READ_TOKEN=""
